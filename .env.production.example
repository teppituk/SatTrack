# =====================================================================
# Production env for AWS (EC2 + Docker Compose, RDS + ElastiCache).
# Copy to `.env.production` on the EC2 host and fill in real values.
# NEVER commit the real .env.production.
# =====================================================================

# --- Database: AWS RDS for PostgreSQL ---------------------------------
# Use the RDS endpoint. Add ?sslmode=require for encrypted connections.
DATABASE_URL="postgresql://USER:PASSWORD@your-db.xxxxxx.ap-southeast-1.rds.amazonaws.com:5432/stacksat?sslmode=require"

# --- NextAuth ---------------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
# No domain yet -> use the EC2 public DNS (http until HTTPS is added).
# e.g. http://ec2-13-250-xx-xx.ap-southeast-1.compute.amazonaws.com
NEXTAUTH_URL="http://YOUR_EC2_PUBLIC_DNS"

# --- Google OAuth -----------------------------------------------------
# Add NEXTAUTH_URL + "/api/auth/callback/google" to the OAuth redirect URIs.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Anthropic Claude (OCR) ------------------------------------------
ANTHROPIC_API_KEY=""

# --- AWS S3 (slip images, private bucket) ----------------------------
# Prefer an EC2 IAM role over static keys. If using a role, leave the
# two keys blank and the SDK will use the instance profile automatically.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
S3_BUCKET_NAME="stacksat-slips"
# Leave empty for real AWS S3 (only set for MinIO/R2).
S3_ENDPOINT=""

# --- Redis: AWS ElastiCache for Redis --------------------------------
# Use the primary endpoint. Use rediss:// if in-transit encryption is on.
REDIS_URL="redis://your-redis.xxxxxx.ng.0001.apse1.cache.amazonaws.com:6379"

# --- Email (SMTP) -----------------------------------------------------
# Option A: Amazon SES SMTP (recommended for production).
#   SMTP_HOST="email-smtp.ap-southeast-1.amazonaws.com"
# Option B: Gmail app password (quick start).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# --- BTCPay (optional, Lightning subscriptions) ----------------------
BTCPAY_URL=""
BTCPAY_API_KEY=""
BTCPAY_STORE_ID=""
BTCPAY_WEBHOOK_SECRET=""
# Keep DISABLED in production (real-money flow). Set "true" only for testing.
ALLOW_DEV_PAYMENTS=""

# --- CoinGecko (price data) ------------------------------------------
COINGECKO_API_KEY=""

# --- App --------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://YOUR_EC2_PUBLIC_DNS"

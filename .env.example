# Database
DATABASE_URL="postgresql://user:password@localhost:5432/crypto_slip_tracker"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic Claude (OCR)
ANTHROPIC_API_KEY=""

# AWS S3 Storage (slip images — private bucket, served via /api/slips)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
S3_BUCKET_NAME="stacksat-slips"
# S3_ENDPOINT: ตั้งเมื่อใช้ S3-compatible (MinIO/Cloudflare R2) เช่น http://localhost:9000
# เว้นว่างไว้ถ้าใช้ AWS S3 จริง
S3_ENDPOINT=""

# Redis (BullMQ Queue)
REDIS_URL="redis://localhost:6379"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@cryptosliptracker.com"

# BTCPay Server (Lightning subscription). เว้นว่าง = ยังไม่ตั้งค่า
BTCPAY_URL=""
BTCPAY_API_KEY=""
BTCPAY_STORE_ID=""
BTCPAY_WEBHOOK_SECRET=""
# ALLOW_DEV_PAYMENTS=true เปิดโหมดจำลองชำระเงิน (ใช้ทดสอบ flow เมื่อยังไม่มี BTCPay)
# อย่าเปิดบน production ที่รับเงินจริง
ALLOW_DEV_PAYMENTS=""

# CoinGecko (price data)
COINGECKO_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

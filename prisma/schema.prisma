generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// key-value สำหรับ config ที่แก้ผ่านหน้า admin ได้ (เช่น BTCPay/Lightning)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String?
  name          String?
  image         String?
  role          String        @default("CUSTOMER_FREE")
  isActive      Boolean       @default(true)
  plan          String        @default("free")
  planExpiresAt DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime      @default(now())
  transactions  Transaction[]
  shareLinks    ShareLink[]
  subscriptions Subscription[]
  accounts      Account[]
  sessions      Session[]
  exchangeApiKeys ExchangeApiKey[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Coin {
  id           String        @id @default(cuid())
  symbol       String        @unique
  name         String
  assetType    String        @default("CRYPTO") // CRYPTO | STOCK
  coingeckoId  String?
  transactions Transaction[]
}

model Exchange {
  id        String   @id @default(cuid())
  code      String   @unique // bitkub, binanceth, binance — ใช้เก็บใน Transaction.exchange
  name      String          // ชื่อแสดงผล เช่น Bitkub
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  coinId       String
  type         String   // BUY or SELL
  amount       Float
  price        Float
  totalValue   Float
  currency     String   // THB, USDT, USD
  exchange     String   // bitkub, binanceth, binance, set, nyse, nasdaq, ...
  txDate       DateTime
  slipImageUrl String?
  externalId   String?  // trade id จาก exchange (สำหรับ sync)
  source       String   @default("manual") // manual | import | sync
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  coin         Coin     @relation(fields: [coinId], references: [id])

  // กันบันทึกซ้ำตอน sync ซ้ำ (externalId = null สำหรับ manual/import → ไม่ชนกันใน Postgres)
  @@unique([userId, exchange, externalId])
}

// API key ของ user ต่อ exchange — secret เก็บแบบเข้ารหัส AES-256-GCM
model ExchangeApiKey {
  id             String    @id @default(cuid())
  userId         String
  exchange       String    // bitkub | binanceth | binance
  apiKeyEnc      String    // เข้ารหัส
  apiSecretEnc   String    // เข้ารหัส
  keyHint        String?   // 4 ตัวท้ายของ apiKey สำหรับโชว์ (••••1234)
  label          String?
  lastSyncAt     DateTime?
  lastSyncStatus String?   // ok | error | running
  lastSyncError  String?
  lastSyncCount  Int       @default(0)
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exchange])
}

model ShareLink {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  config    Json
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  invoiceId   String?
  refCode     String?   @unique
  planType    String?
  amountSats  Int
  status      String    @default("pending") // pending | paid | rejected | expired
  note        String?
  reviewedBy  String?
  reviewedAt  DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String?
  name          String?
  role          String        @default("CUSTOMER")
  isActive      Boolean       @default(true)
  plan          String        @default("free")
  planExpiresAt DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime      @default(now())
  transactions  Transaction[]
  shareLinks    ShareLink[]
  subscriptions Subscription[]
  accounts      Account[]
  sessions      Session[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Coin {
  id           String        @id @default(cuid())
  symbol       String        @unique
  name         String
  assetType    String        @default("CRYPTO") // CRYPTO | STOCK
  coingeckoId  String?
  transactions Transaction[]
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  coinId       String
  type         String   // BUY or SELL
  amount       Float
  price        Float
  totalValue   Float
  currency     String   // THB, USDT, USD
  exchange     String   // bitkub, binanceth, binance, set, nyse, nasdaq, ...
  txDate       DateTime
  slipImageUrl String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  coin         Coin     @relation(fields: [coinId], references: [id])
}

model ShareLink {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  config    Json
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  invoiceId   String
  amountSats  Int
  status      String    @default("pending")
  paidAt      DateTime?
  user        User      @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
